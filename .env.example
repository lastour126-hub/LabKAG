# Application metadata
APP_NAME=LabKAG
APP_VERSION=0.1.0

# Local storage paths
DATA_DIR=data
UPLOAD_DIR=data/uploads
PARSED_DIR=data/parsed
EXTRACTION_DIR=data/extractions

# KAG/graph adapter mode
# true keeps graph/KAG calls in local mock mode for v0.1 development.
MOCK_KAG=true

# Primary graph backend settings used when MOCK_KAG=false and ingest confirm=true.
GRAPH_BACKEND=neo4j
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Extraction mode
# true allows development fallback to the mock extractor when LLM_API_KEY is empty,
# and allows requests with extract_level=mock.
# false makes extraction fail if the real LLM extractor is unavailable.
ALLOW_MOCK_EXTRACTOR=true

# OpenAI-compatible Chat Completions settings for M3 literature extraction.
# Leave LLM_API_KEY empty only when ALLOW_MOCK_EXTRACTOR=true.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=60
